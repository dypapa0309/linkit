{
  "expo": {
    "name": "Linkit",
    "slug": "linkit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.linkit",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.linkit"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "scheme": "linkit",
    "plugins": [
      "expo-font",
      "expo-localization",
      "expo-apple-authentication"
    ]
  }
}
